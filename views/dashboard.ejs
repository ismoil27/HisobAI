<!DOCTYPE html>
<html lang="uz">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HisobAI</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <% if (flashMessage) { %>
        <section class="flash-banner"><%= flashMessage %></section>
      <% } %>

      <section class="surface hero-surface">
        <div class="hero-top">
          <div class="hero-heading">
            <p class="eyebrow"><%= viewMode === "month" ? "TO'LIQ OY" : "BUGUNGI HISOB" %></p>
            <div class="title-row">
              <h1><%= viewMode === "month" ? monthLabel : selectedDateLabel %></h1>
              <div class="header-pills">
                <a
                  class="ghost-btn icon-pill <%= viewMode === "today" ? "active-toggle" : "" %>"
                  href="/?view=today&month=<%= currentMonth %>&date=<%= todayDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
                  title="Bugun"
                  aria-label="Bugun"
                >&#128197;</a>
                <a
                  class="ghost-btn icon-pill <%= viewMode === "month" ? "active-toggle" : "" %>"
                  href="/?view=month&month=<%= currentMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
                  title="To'liq oy"
                  aria-label="To'liq oy"
                >&#128467;</a>
                <% if (isAdmin) { %>
                  <a class="name-pill admin-pill icon-pill" href="/admin?tgUsername=<%= telegramUsername %>" title="Admin" aria-label="Admin">&#128202;</a>
                <% } else { %>
                  <div class="name-pill icon-pill" title="<%= telegramName %>" aria-label="<%= telegramName %>">&#128100;</div>
                <% } %>
              </div>
            </div>
            <p class="hero-subtitle"><%= telegramName %> · <%= currentTimeLabel %> · <%= user.currency || "UZS" %></p>
          </div>
        </div>

        <form method="post" action="/settings/currency" class="currency-form" id="currencyForm">
          <input type="hidden" name="userId" value="<%= user.id %>" />
          <input type="hidden" name="month" value="<%= currentMonth %>" />
          <input type="hidden" name="date" value="<%= selectedDate %>" />
          <input type="hidden" name="view" value="<%= viewMode %>" />
          <input type="hidden" name="tgUserId" value="<%= telegramUserId %>" />
          <input type="hidden" name="tgName" value="<%= telegramName %>" />
          <input type="hidden" name="tgUsername" value="<%= telegramUsername %>" />
          <input type="hidden" name="type" value="<%= draftEntry.type %>" data-draft-target="type" />
          <input type="hidden" name="amount" value="<%= draftEntry.amount %>" data-draft-target="amount" />
          <input type="hidden" name="category" value="<%= draftEntry.category %>" data-draft-target="category" />
          <input type="hidden" name="note" value="<%= draftEntry.note %>" data-draft-target="note" />
          <label class="currency-field">
            <span>Valyuta</span>
            <select name="currency" onchange="this.form.submit()">
              <% currencies.forEach((currency) => { %>
                <option value="<%= currency %>" <%= (user.currency || "UZS") === currency ? "selected" : "" %>><%= currency %></option>
              <% }) %>
            </select>
          </label>
        </form>
      </section>

      <% if (viewMode === "month") { %>
        <section class="surface calendar-surface calendar-priority-surface calendar-expanded">
          <div class="surface-header">
            <a
              href="/?view=<%= viewMode %>&month=<%= previousMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
              class="month-btn"
              aria-label="Oldingi oy"
            >&lsaquo;</a>
            <div class="surface-title-wrap">
              <h2><%= monthLabel %></h2>
              <p>To'liq oy sanalari va kunlik faollik.</p>
            </div>
            <a
              href="/?view=<%= viewMode %>&month=<%= nextMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
              class="month-btn"
              aria-label="Keyingi oy"
            >&rsaquo;</a>
          </div>

          <div class="calendar-focus-row">
            <div class="calendar-focus-pill">
              <span>Tanlangan kun</span>
              <strong><%= selectedDateLabel %></strong>
            </div>
            <div class="calendar-focus-pill">
              <span>Yozuvlar</span>
              <strong><%= entries.length %> ta</strong>
            </div>
          </div>

          <div class="legend">
            <span><i class="dot income"></i> Tushum</span>
            <span><i class="dot expense"></i> Xarajat</span>
            <span><i class="dot debt"></i> Qarz</span>
          </div>

          <div class="weekday-row">
            <% weekdayLabels.forEach((label) => { %>
              <span><%= label %></span>
            <% }) %>
          </div>

          <div class="calendar-grid">
            <% calendarWeeks.forEach((week) => { %>
              <% week.forEach((day) => { %>
                <% if (!day) { %>
                  <div class="calendar-cell empty"></div>
                <% } else { %>
                  <a
                    href="/?view=<%= viewMode %>&month=<%= currentMonth %>&date=<%= day.isoDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
                    class="calendar-cell <%= day.isSelected ? "selected" : "" %> <%= day.isToday ? "today" : "" %>"
                  >
                    <span class="day-number"><%= day.dayNumber %></span>
                    <% if (day.expenseTotal > 0) { %>
                      <span class="day-amount"><%= formatMoney(day.expenseTotal) %></span>
                    <% } %>
                    <span class="day-dots">
                      <% if (day.hasIncome) { %><i class="dot income"></i><% } %>
                      <% if (day.hasExpense) { %><i class="dot expense"></i><% } %>
                      <% if (day.hasDebt) { %><i class="dot debt"></i><% } %>
                    </span>
                  </a>
                <% } %>
              <% }) %>
            <% }) %>
          </div>
        </section>
      <% } %>

      <section class="content-grid month-form-grid <%= viewMode === "month" ? "month-priority-grid" : "" %>">
        <section class="surface day-surface">
          <div class="surface-title-wrap compact-title">
            <% if (viewMode === "today") { %>
              <h2><%= editEntry ? "Yozuvni tahrirlash" : "Yangi yozuv" %></h2>
              <p>Bugungi kun uchun tushum, xarajat yoki qarz qo'shing.</p>
            <% } else { %>
              <h2><%= editEntry ? "Yozuvni tahrirlash" : `${selectedDate} uchun yangi yozuv` %></h2>
              <p>Kalendar ichidan tanlangan sana uchun tur va miqdorni kiriting.</p>
            <% } %>
          </div>

          <form method="post" action="/entries" class="entry-form" id="entryForm">
            <input type="hidden" name="userId" value="<%= user.id %>" />
            <input type="hidden" name="month" value="<%= currentMonth %>" />
            <input type="hidden" name="view" value="<%= viewMode %>" />
            <input type="hidden" name="entryId" value="<%= editEntry ? editEntry.id : "" %>" />
            <input type="hidden" name="transactionDate" value="<%= draftEntry.transactionDate %>" />
            <input type="hidden" name="transactionTime" value="<%= draftEntry.transactionTime %>" />
            <input type="hidden" name="tgUserId" value="<%= telegramUserId %>" />
            <input type="hidden" name="tgName" value="<%= telegramName %>" />
            <input type="hidden" name="tgUsername" value="<%= telegramUsername %>" />

            <div class="type-tabs type-tabs-3">
              <label class="type-option expense">
                <input type="radio" name="type" value="expense" <%= draftEntry.type === "expense" ? "checked" : "" %> data-draft-source="type" />
                <span>Xarajat</span>
              </label>
              <label class="type-option income">
                <input type="radio" name="type" value="income" <%= draftEntry.type === "income" ? "checked" : "" %> data-draft-source="type" />
                <span>Tushum</span>
              </label>
              <label class="type-option debt">
                <input type="radio" name="type" value="debt" <%= draftEntry.type === "debt" ? "checked" : "" %> data-draft-source="type" />
                <span>Qarz</span>
              </label>
            </div>

            <div class="form-grid">
              <label>
                <span>Miqdor</span>
                <input type="number" name="amount" step="0.01" min="0.01" placeholder="25000" value="<%= draftEntry.amount %>" required data-draft-source="amount" />
              </label>
            </div>

            <label>
              <span>Toifa</span>
              <div class="category-combo" id="categoryCombo">
                <input type="text" name="category" placeholder="Ovqat, Maosh, Yo'l, Qarz" value="<%= draftEntry.category %>" required data-draft-source="category" id="categoryInput" autocomplete="off" />
                <button type="button" class="category-toggle" id="categoryToggle" aria-label="Toifa tarixini ochish" aria-expanded="false">
                  <span class="category-toggle-icon">&#8964;</span>
                </button>
                <div class="category-menu" id="categoryMenu" hidden></div>
              </div>
            </label>

            <label>
              <span>Izoh</span>
              <input type="text" name="note" placeholder="Ixtiyoriy izoh" value="<%= draftEntry.note %>" data-draft-source="note" />
            </label>

            <div class="form-actions">
              <button type="submit" class="primary-btn"><%= editEntry ? "Yangilash" : "Saqlash" %></button>
              <% if (editEntry) { %>
                <a class="secondary-btn" href="/?view=<%= viewMode %>&month=<%= currentMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>">Bekor qilish</a>
              <% } %>
            </div>
          </form>
        </section>

        <section class="surface entries-surface">
          <div class="surface-title-wrap compact-title">
            <h2><%= viewMode === "today" ? "Bugungi yozuvlar" : `${selectedDate} yozuvlari` %></h2>
            <p>Tanlangan kun uchun saqlangan yozuvlar.</p>
          </div>

          <% if (entries.length === 0) { %>
            <div class="empty-state">Hozircha yozuv yo'q.</div>
          <% } else { %>
            <div class="entry-list">
              <% entries.forEach((entry) => { %>
                <article class="entry-card <%= entry.type %> prominent-entry">
                  <div>
                    <p class="entry-category"><%= entry.category %></p>
                    <p class="entry-note"><%= entry.note || "Izoh yo'q" %></p>
                  </div>
                  <div class="entry-side">
                    <div class="entry-amount">
                      <span><%= entry.type === "expense" ? "Xarajat" : entry.type === "income" ? "Tushum" : "Qarz" %></span>
                      <strong><%= formatMoney(entry.amount) %></strong>
                    </div>
                    <div class="entry-actions">
                      <a class="micro-btn" href="/?view=<%= viewMode %>&month=<%= currentMonth %>&date=<%= selectedDate %>&editId=<%= entry.id %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>">Tahrirlash</a>
                      <form method="post" action="/entries/<%= entry.id %>/delete">
                        <input type="hidden" name="userId" value="<%= user.id %>" />
                        <input type="hidden" name="month" value="<%= currentMonth %>" />
                        <input type="hidden" name="date" value="<%= selectedDate %>" />
                        <input type="hidden" name="view" value="<%= viewMode %>" />
                        <input type="hidden" name="tgUserId" value="<%= telegramUserId %>" />
                        <input type="hidden" name="tgName" value="<%= telegramName %>" />
                        <input type="hidden" name="tgUsername" value="<%= telegramUsername %>" />
                        <button type="submit" class="micro-btn danger-btn">O'chirish</button>
                      </form>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </section>

      <% if (viewMode !== "month") { %>
        <section class="surface calendar-surface">
          <div class="surface-header">
            <a
              href="/?view=<%= viewMode %>&month=<%= previousMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
              class="month-btn"
              aria-label="Oldingi oy"
            >&lsaquo;</a>
            <div class="surface-title-wrap">
              <h2><%= monthLabel %></h2>
              <p>To'liq oy sanalari va kunlik faollik.</p>
            </div>
            <a
              href="/?view=<%= viewMode %>&month=<%= nextMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
              class="month-btn"
              aria-label="Keyingi oy"
            >&rsaquo;</a>
          </div>

          <div class="legend">
            <span><i class="dot income"></i> Tushum</span>
            <span><i class="dot expense"></i> Xarajat</span>
            <span><i class="dot debt"></i> Qarz</span>
          </div>

          <div class="weekday-row">
            <% weekdayLabels.forEach((label) => { %>
              <span><%= label %></span>
            <% }) %>
          </div>

          <div class="calendar-grid">
            <% calendarWeeks.forEach((week) => { %>
              <% week.forEach((day) => { %>
                <% if (!day) { %>
                  <div class="calendar-cell empty"></div>
                <% } else { %>
                  <a
                    href="/?view=<%= viewMode %>&month=<%= currentMonth %>&date=<%= day.isoDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>"
                    class="calendar-cell <%= day.isSelected ? "selected" : "" %> <%= day.isToday ? "today" : "" %>"
                  >
                    <span class="day-number"><%= day.dayNumber %></span>
                    <% if (day.expenseTotal > 0) { %>
                      <span class="day-amount"><%= formatMoney(day.expenseTotal) %></span>
                    <% } %>
                    <span class="day-dots">
                      <% if (day.hasIncome) { %><i class="dot income"></i><% } %>
                      <% if (day.hasExpense) { %><i class="dot expense"></i><% } %>
                      <% if (day.hasDebt) { %><i class="dot debt"></i><% } %>
                    </span>
                  </a>
                <% } %>
              <% }) %>
            <% }) %>
          </div>
        </section>
      <% } %>
    </div>

    <script>
      const categoryHistory = <%- JSON.stringify(categoryHistory || { expense: [], income: [], debt: [] }) %>;

      if (window.Telegram && window.Telegram.WebApp) {
        const app = window.Telegram.WebApp;
        app.ready();
        app.expand();

        const user = app.initDataUnsafe && app.initDataUnsafe.user;
        if (user) {
          const params = new URLSearchParams(window.location.search);
          const tgId = String(user.id);
          const tgName = user.first_name || "";
          const tgUsername = user.username || "";
          if (params.get("tgUserId") !== tgId || params.get("tgName") !== tgName || params.get("tgUsername") !== tgUsername) {
            params.set("tgUserId", tgId);
            params.set("tgName", tgName);
            params.set("tgUsername", tgUsername);
            window.location.replace(`${window.location.pathname}?${params.toString()}`);
          }
        }
      }

      const currencyForm = document.getElementById("currencyForm");
      const entryForm = document.getElementById("entryForm");
      const categoryInput = document.getElementById("categoryInput");
      const categoryToggle = document.getElementById("categoryToggle");
      const categoryMenu = document.getElementById("categoryMenu");
      const categoryCombo = document.getElementById("categoryCombo");

      if (currencyForm && entryForm) {
        const getCurrentType = () => {
          const checkedType = entryForm.querySelector('[data-draft-source="type"]:checked');
          return checkedType ? checkedType.value : "expense";
        };

        const renderCategoryHistory = () => {
          if (!categoryMenu) {
            return;
          }

          const currentType = getCurrentType();
          const items = Array.isArray(categoryHistory[currentType]) ? categoryHistory[currentType] : [];
          const currentValue = categoryInput ? categoryInput.value.trim() : "";
          const filtered = currentValue
            ? items.filter((item) => String(item.category || "").toLowerCase().includes(currentValue.toLowerCase()))
            : items;

          if (categoryToggle) {
            categoryToggle.disabled = items.length === 0;
          }

          if (filtered.length === 0) {
            categoryMenu.innerHTML = '<div class="category-empty">Tarix topilmadi</div>';
            return;
          }

          categoryMenu.innerHTML = filtered
            .map((item) => {
              const label = String(item.category || "");
              const activeClass = currentValue === label ? " active" : "";
              return `<button type="button" class="category-option${activeClass}" data-category-value="${encodeURIComponent(label)}">${label}</button>`;
            })
            .join("");
        };

        const closeCategoryMenu = () => {
          if (!categoryMenu || !categoryToggle) {
            return;
          }
          categoryMenu.hidden = true;
          categoryToggle.setAttribute("aria-expanded", "false");
        };

        const openCategoryMenu = () => {
          if (!categoryMenu || !categoryToggle || categoryToggle.disabled) {
            return;
          }
          renderCategoryHistory();
          categoryMenu.hidden = false;
          categoryToggle.setAttribute("aria-expanded", "true");
        };

        const syncDraft = () => {
          const typeTarget = currencyForm.querySelector('[data-draft-target="type"]');
          if (typeTarget) {
            typeTarget.value = getCurrentType();
          }

          ["amount", "category", "note"].forEach((name) => {
            const source = entryForm.querySelector(`[data-draft-source="${name}"]`);
            const target = currencyForm.querySelector(`[data-draft-target="${name}"]`);
            if (source && target) {
              target.value = source.value;
            }
          });
        };

        if (categoryToggle && categoryMenu && categoryInput && categoryCombo) {
          categoryToggle.addEventListener("click", () => {
            if (categoryMenu.hidden) {
              openCategoryMenu();
            } else {
              closeCategoryMenu();
            }
          });

          categoryMenu.addEventListener("click", (event) => {
            const option = event.target.closest("[data-category-value]");
            if (!option) {
              return;
            }

            categoryInput.value = decodeURIComponent(option.getAttribute("data-category-value") || "");
            syncDraft();
            closeCategoryMenu();
          });

          categoryInput.addEventListener("focus", renderCategoryHistory);
          categoryInput.addEventListener("input", () => {
            syncDraft();
            if (!categoryMenu.hidden) {
              renderCategoryHistory();
            }
          });

          document.addEventListener("click", (event) => {
            if (!categoryCombo.contains(event.target)) {
              closeCategoryMenu();
            }
          });
        }

        entryForm.addEventListener("input", syncDraft);
        entryForm.addEventListener("change", (event) => {
          if (event.target && event.target.name === "type") {
            renderCategoryHistory();
            closeCategoryMenu();
          }
          syncDraft();
        });
        currencyForm.addEventListener("submit", syncDraft);
        renderCategoryHistory();
        syncDraft();
      }
    </script>
  </body>
</html>
