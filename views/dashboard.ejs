<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HisobAI</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <% if (flashMessage) { %>
        <section class="flash-banner"><%= flashMessage %></section>
      <% } %>

      <section class="surface calendar-surface">
        <div class="surface-header">
          <a href="/?month=<%= previousMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>" class="month-btn" aria-label="Previous month">&lsaquo;</a>
          <div class="surface-title-wrap">
            <h1><%= monthLabel %></h1>
            <% if (monthSummary.comparison) { %><p><%= monthSummary.comparison %></p><% } %>
          </div>
          <a href="/?month=<%= nextMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>" class="month-btn" aria-label="Next month">&rsaquo;</a>
        </div>

        <div class="mini-toolbar">
          <a class="ghost-btn" href="/?month=<%= currentMonth %>&date=<%= new Date().toISOString().slice(0, 10) %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>">Today</a>
          <% if (isAdmin) { %>
            <a class="name-pill admin-pill" href="/admin?tgUsername=<%= telegramUsername %>">Admin</a>
          <% } else { %>
            <div class="name-pill"><%= telegramName %></div>
          <% } %>
        </div>

        <div class="legend">
          <span><i class="dot income"></i> Income</span>
          <span><i class="dot expense"></i> Expense</span>
          <span><i class="dot debt"></i> Qarz</span>
        </div>

        <div class="weekday-row">
          <span>Su</span>
          <span>Mo</span>
          <span>Tu</span>
          <span>We</span>
          <span>Th</span>
          <span>Fr</span>
          <span>Sa</span>
        </div>

        <div class="calendar-grid">
          <% calendarWeeks.forEach((week) => { %>
            <% week.forEach((day) => { %>
              <% if (!day) { %>
                <div class="calendar-cell empty"></div>
              <% } else { %>
                <a href="/?month=<%= currentMonth %>&date=<%= day.isoDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>" class="calendar-cell <%= day.isSelected ? "selected" : "" %> <%= day.isToday ? "today" : "" %>">
                  <span class="day-number"><%= day.dayNumber %></span>
                  <span class="day-dots">
                    <% if (day.hasIncome) { %><i class="dot income"></i><% } %>
                    <% if (day.hasExpense) { %><i class="dot expense"></i><% } %>
                    <% if (day.hasDebt) { %><i class="dot debt"></i><% } %>
                  </span>
                </a>
              <% } %>
            <% }) %>
          <% }) %>
        </div>
      </section>

      <section class="content-grid">
        <section class="surface day-surface">
          <div class="surface-title-wrap compact-title">
            <h2><%= editEntry ? "Edit Entry" : selectedDate %></h2>
            <p>
              Expense <strong><%= formatMoney(dailyTotals.expense_total) %></strong>
              · Income <strong><%= formatMoney(dailyTotals.income_total) %></strong>
              · Qarz <strong><%= formatMoney(dailyTotals.debt_total) %></strong>
            </p>
          </div>

          <form method="post" action="/entries" class="entry-form">
            <input type="hidden" name="userId" value="<%= user.id %>" />
            <input type="hidden" name="month" value="<%= currentMonth %>" />
            <input type="hidden" name="entryId" value="<%= editEntry ? editEntry.id : "" %>" />
            <input type="hidden" name="tgUserId" value="<%= telegramUserId %>" />
            <input type="hidden" name="tgName" value="<%= telegramName %>" />
            <input type="hidden" name="tgUsername" value="<%= telegramUsername %>" />

            <div class="type-tabs type-tabs-3">
              <label class="type-option expense">
                <input type="radio" name="type" value="expense" <%= !editEntry || editEntry.type === "expense" ? "checked" : "" %> />
                <span>Expense</span>
              </label>
              <label class="type-option income">
                <input type="radio" name="type" value="income" <%= editEntry && editEntry.type === "income" ? "checked" : "" %> />
                <span>Income</span>
              </label>
              <label class="type-option debt">
                <input type="radio" name="type" value="debt" <%= editEntry && editEntry.type === "debt" ? "checked" : "" %> />
                <span>Qarz</span>
              </label>
            </div>

            <div class="form-grid">
              <label>
                <span>Amount</span>
                <input type="number" name="amount" step="0.01" min="0.01" placeholder="25.50" value="<%= editEntry ? editEntry.amount : "" %>" required />
              </label>
              <label>
                <span>Date</span>
                <input type="date" name="transactionDate" value="<%= editEntry ? editEntry.transaction_date : selectedDate %>" required />
              </label>
            </div>

            <label>
              <span>Category</span>
              <input type="text" name="category" placeholder="Food, Salary, Transport, Borrowed" value="<%= editEntry ? editEntry.category : "" %>" required />
            </label>

            <label>
              <span>Note</span>
              <input type="text" name="note" placeholder="Optional note" value="<%= editEntry ? editEntry.note : "" %>" />
            </label>

            <div class="form-actions">
              <button type="submit" class="primary-btn"><%= editEntry ? "Update" : "Save" %></button>
              <% if (editEntry) { %>
                <a class="secondary-btn" href="/?month=<%= currentMonth %>&date=<%= selectedDate %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>">Cancel</a>
              <% } %>
            </div>
          </form>
        </section>

        <section class="surface entries-surface">
          <div class="surface-title-wrap compact-title">
            <h2>Entries</h2>
            <p><%= entries.length %> item(s)</p>
          </div>

          <% if (entries.length === 0) { %>
            <div class="empty-state">No entries on this day yet.</div>
          <% } else { %>
            <div class="entry-list">
              <% entries.forEach((entry) => { %>
                <article class="entry-card <%= entry.type %>">
                  <div>
                    <p class="entry-category"><%= entry.category %></p>
                    <p class="entry-note"><%= entry.note || "No note" %></p>
                  </div>
                  <div class="entry-side">
                    <div class="entry-amount">
                      <span><%= entry.type === "expense" ? "Spending" : entry.type === "income" ? "Income" : "Qarz" %></span>
                      <strong><%= formatMoney(entry.amount) %></strong>
                    </div>
                    <div class="entry-actions">
                      <a class="micro-btn" href="/?month=<%= currentMonth %>&date=<%= selectedDate %>&editId=<%= entry.id %>&tgUserId=<%= telegramUserId %>&tgName=<%= encodeURIComponent(telegramName) %>&tgUsername=<%= telegramUsername %>">Edit</a>
                      <form method="post" action="/entries/<%= entry.id %>/delete">
                        <input type="hidden" name="userId" value="<%= user.id %>" />
                        <input type="hidden" name="month" value="<%= currentMonth %>" />
                        <input type="hidden" name="date" value="<%= selectedDate %>" />
                        <input type="hidden" name="tgUserId" value="<%= telegramUserId %>" />
                        <input type="hidden" name="tgName" value="<%= telegramName %>" />
                        <input type="hidden" name="tgUsername" value="<%= telegramUsername %>" />
                        <button type="submit" class="micro-btn danger-btn">Delete</button>
                      </form>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </section>
    </div>
    <script>
      if (window.Telegram && window.Telegram.WebApp) {
        const app = window.Telegram.WebApp;
        app.ready();
        app.expand();

        const user = app.initDataUnsafe && app.initDataUnsafe.user;
        if (user) {
          const params = new URLSearchParams(window.location.search);
          const tgId = String(user.id);
          const tgName = user.first_name || "";
          const tgUsername = user.username || "";
          if (params.get("tgUserId") !== tgId || params.get("tgName") !== tgName || params.get("tgUsername") !== tgUsername) {
            params.set("tgUserId", tgId);
            params.set("tgName", tgName);
            params.set("tgUsername", tgUsername);
            window.location.replace(`${window.location.pathname}?${params.toString()}`);
          }
        }
      }
    </script>
  </body>
</html>
